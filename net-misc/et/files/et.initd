description="EternalTerminal Server"
pidfile="/run/${RC_SVCNAME}.pid"
command="/usr/bin/etserver"
command_args="--cfgfile=/etc/et.cfg --logtostdout"
command_background="true"

depend() {
    need net
    use logger
}